{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SkillManifest",
  "type": "object",
  "required": [
    "name",
    "kind",
    "links",
    "capabilities",
    "artifacts"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "kind": {
      "const": "skill"
    },
    "category": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "links": {
      "type": "object",
      "properties": {
        "calls": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "reads_context": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "capabilities": {
      "type": "object",
      "properties": {
        "requires": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "artifacts": {
      "type": "object",
      "properties": {
        "consumes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "produces": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
